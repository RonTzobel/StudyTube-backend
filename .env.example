# ============================================================
# StudyTube Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
APP_NAME=StudyTube
DEBUG=false

# Runtime environment: development | production | test
ENV=development

# --- Database ---
# PostgreSQL runs on Aiven (cloud). Do NOT replace this with a local URL.
# The database is NOT in Docker — it always points to the Aiven cloud host.
#
# Format:  postgresql+psycopg://user:password@host:port/dbname?sslmode=require
# Example: postgresql+psycopg://avnadmin:password@pg-host.aivencloud.com:12345/defaultdb?sslmode=require
#
# Copy your full Aiven connection string here. The "+psycopg" driver prefix
# is required (psycopg v3). If Aiven gives you a plain postgresql:// URL,
# app/database/session.py converts it automatically.
DATABASE_URL=postgresql+psycopg://avnadmin:YOURPASSWORD@pg-PROJECT.aivencloud.com:PORT/defaultdb?sslmode=require

# --- Redis ---
# When running with Docker Compose (the normal way), you can leave this as
# redis://localhost:6379/0. docker-compose.yml overrides REDIS_URL to
# redis://redis:6379/0 for backend and worker containers automatically.
# Only change this if you are running the backend/worker OUTSIDE Docker.
REDIS_URL=redis://localhost:6379/0

# --- File uploads ---
UPLOAD_DIR=uploads

# --- CORS ---
# JSON array of allowed frontend origins.
# For production, restrict to your deployed frontend domain only:
#   CORS_ALLOWED_ORIGINS=["https://app.studytube.com"]
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Security ---
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- AWS S3 ---
# Used to store uploaded video files. Videos are never stored in PostgreSQL.
# Required IAM permissions: s3:PutObject, s3:DeleteObject, s3:GetObject
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# --- OpenAI ---
# Required for /ask, /quiz, /summarize, and chat endpoints.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Google OAuth (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly what is registered in Google Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

# --- Frontend ---
# After Google OAuth the backend redirects to FRONTEND_URL/auth/callback?token=
FRONTEND_URL=http://localhost:5173

# --- Whisper transcription ---
# Model size: base | small (default) | medium
# See app/config/settings.py for full speed/quality guidance.
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_VAD_FILTER=true
WHISPER_CPU_THREADS=0

# --- Worker ---
# Maximum seconds a video pipeline job may run before RQ kills it.
# Default 7200 = 2 hours. Increase for very long videos on slow hardware.
VIDEO_PIPELINE_JOB_TIMEOUT=7200

# --- Embedding model ---
# Both chunk embedding (worker) and query embedding (backend) MUST use the same model.
# If you change this, re-process all existing videos to regenerate embeddings.
# To revert to the English-only model: all-MiniLM-L6-v2
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- RAG quality gates ---
# Calibrated for paraphrase-multilingual-MiniLM-L12-v2.
# If you switch back to all-MiniLM-L6-v2, lower these to 0.10 / 0.22.
RAG_LOW_THRESHOLD=0.20
RAG_GOOD_THRESHOLD=0.40
